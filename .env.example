# Banco de dados (Neon Postgres — https://neon.tech)
# Use a connection string "pooled" do painel do Neon.
DATABASE_URL="postgresql://usuario:senha@ep-xxxx-pooler.regiao.aws.neon.tech/neondb?sslmode=require"

# Better Auth (https://better-auth.com)
# Gere o secret com: openssl rand -base64 32  (ou npx @better-auth/cli secret)
BETTER_AUTH_SECRET="troque-por-um-segredo-aleatorio"
# URL base da aplicação (em produção, a URL do deploy na Vercel)
BETTER_AUTH_URL="http://localhost:3000"

# Google OAuth (opcional — login com Google fica desativado se vazio)
# Console: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
